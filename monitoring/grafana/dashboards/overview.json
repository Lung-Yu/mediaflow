{
  "title": "MediaFlow",
  "uid": "mediaflow-overview",
  "tags": ["mediaflow"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1, "type": "row", "title": "服務健康",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2, "type": "stat", "title": "Whisper",
      "gridPos": {"h": 3, "w": 8, "x": 0, "y": 1},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "probe_success{instance=\"http://host.docker.internal:9001/health\"}"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 3, "type": "stat", "title": "Ollama",
      "gridPos": {"h": 3, "w": 8, "x": 8, "y": 1},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "probe_success{instance=\"http://host.docker.internal:11434/api/tags\"}"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 4, "type": "stat", "title": "Diarize",
      "gridPos": {"h": 3, "w": 8, "x": 16, "y": 1},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "probe_success{instance=\"http://host.docker.internal:9003/health\"}"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 5, "type": "row", "title": "任務狀態",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 4},
      "collapsed": false
    },
    {
      "id": 6, "type": "stat", "title": "Waiting",
      "gridPos": {"h": 3, "w": 6, "x": 0, "y": 5},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"queued\"}"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}}}
    },
    {
      "id": 7, "type": "stat", "title": "Processing",
      "gridPos": {"h": 3, "w": 6, "x": 6, "y": 5},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"submitted\"}"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 2}]}}}
    },
    {
      "id": 8, "type": "stat", "title": "✓ Completed",
      "gridPos": {"h": 3, "w": 6, "x": 12, "y": 5},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"completed\"}"}],
      "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}]}}}
    },
    {
      "id": 9, "type": "stat", "title": "✗ Failed",
      "gridPos": {"h": 3, "w": 6, "x": 18, "y": 5},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"failed\"}"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "id": 10, "type": "row", "title": "效能分析",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 8},
      "collapsed": false
    },
    {
      "id": 11, "type": "timeseries", "title": "Stage Duration — P50 / P95 / P99",
      "gridPos": {"h": 8, "w": 14, "x": 0, "y": 9},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.50, rate(mediaflow_stage_duration_seconds_bucket[10m]))", "legendFormat": "P50 {{stage}}"},
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.95, rate(mediaflow_stage_duration_seconds_bucket[10m]))", "legendFormat": "P95 {{stage}}"},
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.99, rate(mediaflow_stage_duration_seconds_bucket[10m]))", "legendFormat": "P99 {{stage}}"}
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Job Status Over Time",
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 9},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"completed\"}", "legendFormat": "Completed"},
        {"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"failed\"}", "legendFormat": "Failed"},
        {"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"queued\"}", "legendFormat": "Waiting"},
        {"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"submitted\"}", "legendFormat": "Processing"}
      ]
    },
    {
      "id": 20, "type": "row", "title": "主機資源",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
      "collapsed": false
    },
    {
      "id": 21, "type": "timeseries", "title": "CPU 使用率",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 18},
      "targets": [{
        "datasource": {"uid": "prometheus"},
        "expr": "100 - (avg by() (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 22, "type": "timeseries", "title": "記憶體使用",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 18},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "node_memory_active_bytes", "legendFormat": "Active"},
        {"datasource": {"uid": "prometheus"}, "expr": "node_memory_internal_bytes", "legendFormat": "Wired"},
        {"datasource": {"uid": "prometheus"}, "expr": "node_memory_swap_used_bytes", "legendFormat": "Swap Used"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 23, "type": "timeseries", "title": "GPU / ANE 使用率",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 18},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "apple_gpu_utilization_percent", "legendFormat": "GPU %"},
        {"datasource": {"uid": "prometheus"}, "expr": "apple_gpu_power_watts", "legendFormat": "GPU W"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0}}
    },
    {
      "id": 13, "type": "row", "title": "統計",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "collapsed": false
    },
    {
      "id": 14, "type": "stat", "title": "Total Completed",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 26},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"completed\"}"}],
      "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}]}}}
    },
    {
      "id": 15, "type": "stat", "title": "Total Failed",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 26},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count{status=\"failed\"}"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "id": 16, "type": "piechart", "title": "Job Status Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "mediaflow_jobs_count", "legendFormat": "{{status}}"}]
    }
  ]
}
