    {
      "id": "dag_detail_text",
      "type": "text",
      "x": 1585,
      "y": 372,
      "width": 460,
      "height": 280,
      "angle": 0,
      "strokeColor": "#064e3b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
      "roundness": null,
      "boundElements": [],
      "isDeleted": false,
      "seed": 444002,
      "version": 1,
      "versionNonce": 2,
      "updated": 1781670000001,
      "link": null,
      "locked": false,
      "text": "DAG-Service internals:\n1. on trigger (from Project Service):\n   → jobs: status=queued, retry_count=0, dag_flow_id\n   → query dag_flows by dag_flow_id\n     (if omitted → WHERE is_default=true)\n   → stage_plan = dag_flows.stage_plan\n   → enqueue MQ: { job_id, stage_plan,\n                   retry_attempt: 0,\n                   resume_from_stage: \"preprocess\" }\n\n2. on stage callback (HTTP from Progress Worker):\n   → append events: { stage, status, retry_attempt, ts }\n   → all stages success? → jobs.status = completed\n   → stage failed? → retry decision:\n\n3. retry decision:\n   retry_count < max  → retry_count++\n                        re-enqueue resume_from_stage: failed_stage\n                        ▎ Worker overwrites existing stage outputs (idempotent)\n   retry_count >= max → jobs.status = failed\n                        webhook notify → Project Service",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DAG-Service internals:\n1. on trigger (from Project Service):\n   → jobs: status=queued, retry_count=0, dag_flow_id\n   → query dag_flows by dag_flow_id\n     (if omitted → WHERE is_default=true)\n   → stage_plan = dag_flows.stage_plan\n   → enqueue MQ: { job_id, stage_plan,\n                   retry_attempt: 0,\n                   resume_from_stage: \"preprocess\" }\n\n2. on stage callback (HTTP from Progress Worker):\n   → append events: { stage, status, retry_attempt, ts }\n   → all stages success? → jobs.status = completed\n   → stage failed? → retry decision:\n\n3. retry decision:\n   retry_count < max  → retry_count++\n                        re-enqueue resume_from_stage: failed_stage\n                        ▎ Worker overwrites existing stage outputs (idempotent)\n   retry_count >= max → jobs.status = failed\n                        webhook notify → Project Service",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "stage_dag_bg",
      "type": "rectangle",
