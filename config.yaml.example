# mediaflow configuration
# Copy to config.yaml and fill in values

pipeline:
  workspace_dir: ./workspace       # 1_input, 3_output, 4_archive subdirs
  supported_formats:
    - .mp4
    - .m4a
    - .mp3
    - .wav
    - .flac
  recording_type: auto             # auto | course | meeting | general
  stages:
    - id: preprocess
      enabled: true
    - id: transcribe
      enabled: true
    - id: verify_segments
      enabled: false               # re-transcribe low-confidence segments with whisper-large-v3
    - id: correct_srt
      enabled: false               # Ollama homophone correction pass (~30s)
    - id: diarize
      enabled: false               # speaker diarization via speechbrain ECAPA-TDNN :9003
    - id: summarize
      enabled: true
    - id: detect_chapters
      enabled: false               # silence-gap chapter detection + Ollama titling

verification:
  logprob_threshold: -0.8          # flag segments with avg_logprob below this
  no_speech_threshold: 0.7         # flag segments with no_speech_prob above this

chapters:
  min_silence_sec: 30.0            # minimum silence gap to be a chapter boundary
  max_chapters: 8                  # cap on total chapters generated

diarization:
  service_url: http://localhost:9003
  num_speakers: null               # set to known count for better accuracy (e.g. 2)
  max_speakers: 6                  # cap for auto-detection via silhouette score
  speaker_format: "【{speaker}】"   # prefix format; use "" to disable labels in SRT
  speaker_names: {}                # display name override after diarization e.g. {SPEAKER_00: 老師}
  library_path: data/speaker_library.json  # voiceprint library for named speaker matching
  match_threshold: 0.70            # cosine similarity threshold; lower = more permissive

whisper:
  service_url: http://localhost:9001
  language: zh
  # initial_prompt: warm up Whisper with domain vocabulary to improve accuracy.
  # Leave empty ("") or omit to disable. Restart watcher after editing.
  # Example for Java/Spring courses:
  # initial_prompt: "日誌 Actuator MDC Spring Boot SpringBoot Logger SLF4J Logback AOP IoC DI Bean JPA Hibernate Maven Gradle JVM GC"
  initial_prompt: ""

ollama:
  service_url: http://localhost:11434
  model: llama3

redis:
  host: localhost
  port: 6379
  stream_key: mediaflow:events
  consumer_group: api-consumers

api:
  event_url: http://localhost:8080/events/stage-complete  # where pipeline pushes events

notification:
  webhook_url: ""   # optional: POST on task completion (n8n, Slack, ntfy, etc.)

lifecycle:
  # Retention policy for each data tier.
  # Values: "immediate" | "Nd" (e.g. "30d", "90d") | "forever" (default for all)
  # "immediate" = delete as soon as the pipeline stage that produced it completes.
  # Restart watcher after editing.
  wav:          immediate   # 2_processing/_clean.wav (~200 MB/file, regenerable via preprocess)
  archive:      30d         # 4_archive/ originals  — set "forever" if no other backup exists
  output:       forever     # 3_output/ SRT + summaries — small; "forever" recommended
  minio_input:  7d          # mediaflow-input MinIO bucket TTL (uploaded originals)
  minio_output: 90d         # mediaflow-output MinIO bucket TTL (output backups)
  # Note: enabling wav=immediate + archive=immediate means rerun-from-transcribe
  # or rerun-from-preprocess will require re-uploading the original file.

minio:
  endpoint: localhost:9000
  public_endpoint: localhost:9000   # browser-facing URL for presigned uploads (set to host IP/domain if remote)
  access_key: mediaflow
  secret_key: changeme
  secure: false
  input_bucket: mediaflow-input
  output_bucket: mediaflow-output

upload:
  max_file_bytes: 5368709120   # 5 GB
  part_size_bytes: 104857600   # 100 MB per part
  max_concurrent: 2
